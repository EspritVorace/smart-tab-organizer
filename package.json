{
  "name": "smart-tab-organizer",
  "version": "1.1.4",
  "packageManager": "pnpm@10.33.2",
  "type": "module",
  "scripts": {
    "test": "vitest run --config vitest.simple.config.ts",
    "test:watch": "vitest --watch --config vitest.simple.config.ts",
    "test:ui": "vitest --ui --config vitest.simple.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.simple.config.ts && node scripts/inject-coverage-into-ctrf.mjs",
    "test:e2e": "wxt build && xvfb-maybe playwright test",
    "test:e2e:ui": "wxt build && playwright test --ui",
    "test:e2e:headed": "wxt build && playwright test --headed",
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:analyze": "wxt build --analyze",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "postinstall": "wxt prepare",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "a11y:storybook:run": "storybook build -o storybook-static && concurrently -k -s first -n SB,TEST \"http-server storybook-static -p 6007 -s\" \"wait-on tcp:6007 && test-storybook --url http://127.0.0.1:6007\"",
    "a11y:storybook:consolidate": "node scripts/a11y-storybook-consolidate.mjs",
    "a11y:storybook": "pnpm a11y:storybook:run ; pnpm a11y:storybook:consolidate",
    "a11y:e2e": "A11Y_ENABLED=true wxt build && A11Y_ENABLED=true xvfb-maybe playwright test",
    "a11y:report": "node scripts/a11y-report.mjs",
    "a11y": "pnpm a11y:storybook && pnpm a11y:e2e && pnpm a11y:report",
    "screenshots": "pnpm build && xvfb-maybe playwright test --config=e2e-screenshots/playwright.screenshots.config.ts",
    "docs:dev": "pnpm --dir docs dev",
    "docs:build": "pnpm --dir docs build",
    "docs:preview": "pnpm --dir docs preview",
    "design-system:bundle": "node scripts/build-design-system-bundle.mjs",
    "design-system:zip": "node scripts/build-design-system-bundle.mjs --zip"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.2",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "9.1.20",
    "@storybook/addon-docs": "^9.0.13",
    "@storybook/react": "9.1.20",
    "@storybook/react-vite": "^9.0.13",
    "@storybook/test-runner": "0.23.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@types/sharp": "^0.32.0",
    "@vitest/coverage-v8": "2.1.9",
    "@vitest/eslint-plugin": "^1.6.15",
    "axe-playwright": "2.2.2",
    "concurrently": "9.1.2",
    "esbuild-wasm": "^0.25.6",
    "eslint": "^10.2.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-playwright": "^2.10.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "happy-dom": "^15.11.7",
    "http-server": "14.1.1",
    "playwright-ctrf-json-reporter": "^0.0.27",
    "postcss": "^8.5.6",
    "sharp": "^0.34.5",
    "storybook": "^9.0.13",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.58.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^2.1.8",
    "vitest-ctrf-json-reporter": "^0.0.3",
    "wait-on": "8.0.1",
    "wxt": "^0.20.13",
    "xvfb-maybe": "^0.2.1"
  },
  "dependencies": {
    "@dnd-kit/abstract": "^0.3.2",
    "@dnd-kit/helpers": "0.3.2",
    "@dnd-kit/react": "^0.3.2",
    "@hookform/resolvers": "^5.1.1",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@radix-ui/themes": "^3.2.1",
    "@vitejs/plugin-react": "^4.6.0",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.522.0",
    "next-themes": "^0.4.6",
    "react": "^18.3.1",
    "react-accessible-treeview": "^2.11.2",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.58.1",
    "zod": "^3.25.67"
  },
  "overrides": {
    "rollup": "npm:@rollup/wasm-node@^4.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "spawn-sync",
      "sharp"
    ],
    "patchedDependencies": {
      "vitest-ctrf-json-reporter@0.0.3": "patches/vitest-ctrf-json-reporter@0.0.3.patch"
    },
    "ignoredBuiltDependencies": [
      "@swc/core"
    ]
  }
}
