{
  "name": "smart-tab-organizer",
  "version": "1.1.2",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "scripts": {
    "test": "vitest run --config vitest.simple.config.ts",
    "test:watch": "vitest --watch --config vitest.simple.config.ts",
    "test:ui": "vitest --ui --config vitest.simple.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.simple.config.ts && node scripts/inject-coverage-into-ctrf.mjs",
    "test:e2e": "wxt build && xvfb-maybe playwright test",
    "test:e2e:ui": "wxt build && playwright test --ui",
    "test:e2e:headed": "wxt build && playwright test --headed",
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:analyze": "wxt build --analyze",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "screenshots": "pnpm build && xvfb-maybe playwright test --config=e2e-screenshots/playwright.screenshots.config.ts",
    "docs:dev": "pnpm --dir docs dev",
    "docs:build": "pnpm --dir docs build",
    "docs:preview": "pnpm --dir docs preview"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@storybook/addon-docs": "^9.0.13",
    "@storybook/react-vite": "^9.0.13",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@types/sharp": "^0.32.0",
    "@vitest/coverage-v8": "2.1.9",
    "esbuild-wasm": "^0.25.6",
    "happy-dom": "^15.11.7",
    "playwright-ctrf-json-reporter": "^0.0.27",
    "postcss": "^8.5.6",
    "sharp": "^0.34.5",
    "storybook": "^9.0.13",
    "typescript": "^5.2.2",
    "vitest": "^2.1.8",
    "vitest-ctrf-json-reporter": "^0.0.3",
    "wxt": "^0.20.13",
    "xvfb-maybe": "^0.2.1"
  },
  "dependencies": {
    "@dnd-kit/abstract": "^0.3.2",
    "@dnd-kit/helpers": "0.3.2",
    "@dnd-kit/react": "^0.3.2",
    "@hookform/resolvers": "^5.1.1",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/themes": "^3.2.1",
    "@vitejs/plugin-react": "^4.6.0",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.522.0",
    "next-themes": "^0.4.6",
    "react": "^18.3.1",
    "react-accessible-treeview": "^2.11.2",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.58.1",
    "zod": "^3.25.67"
  },
  "overrides": {
    "rollup": "npm:@rollup/wasm-node@^4.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "spawn-sync",
      "sharp"
    ],
    "patchedDependencies": {
      "vitest-ctrf-json-reporter@0.0.3": "patches/vitest-ctrf-json-reporter@0.0.3.patch"
    }
  }
}
